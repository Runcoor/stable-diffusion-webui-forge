# Copy this file to .env on each host (do NOT commit .env).
#   cp .env.example .env
#   $EDITOR .env

# Which physical GPU to bind to (matches `nvidia-smi -L` index).
GPU_DEVICE_ID=0

# Host ports — change if something already listens on these.
# Forge WebUI/API (7860 default). Adapter (OpenAI-compat, 8080 default).
# ComfyUI graph-based workflow engine (8188 default).
FORGE_PORT=7860
ADAPTER_PORT=8080
COMFYUI_PORT=8188

# GPU for ComfyUI. Falls back to GPU_DEVICE_ID if unset, i.e. shares the card
# with Forge by default. Switch to a different physical index (e.g. 3) once
# you want to run heavy jobs on both engines concurrently.
# COMFYUI_GPU_DEVICE_ID=3

# Forge HTTP API basic auth — used by both WebUI access and the sd-adapter sidecar.
# CHANGE BOTH before deploying — these are public defaults.
API_USER=admin
API_PASS=please-change-me

# Bearer token enforced by the OpenAI-compatible adapter on /v1/* endpoints.
# Strongly recommended whenever ADAPTER_PORT is reachable from anywhere other
# than this host. Generate one with:
#     openssl rand -hex 24
# Leave empty only if the adapter is reachable solely via a private docker
# network or trusted loopback.
ADAPTER_KEY=

# Default generation params for the OpenAI adapter.
# OpenAI's image protocol has no negative-prompt field, so this value is
# applied to every /v1/images/generations request. Leave empty unless you
# have a model-specific quality issue you want to suppress globally.
# (Note: SDXL responds weakly to negatives; Flux ignores them entirely.)
DEFAULT_STEPS=30
DEFAULT_SAMPLER=DPM++ 2M Karras
DEFAULT_CFG=7
DEFAULT_NEGATIVE_PROMPT=
